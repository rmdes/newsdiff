		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.5",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.2"
	},
	"dependencies": {
