{
	"name": "newsdiff",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"test": "vitest run",
		"test:watch": "vitest",
		"migrate": "tsx src/lib/server/db/migrate.ts",
